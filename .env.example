# ═══════════════════════════════════════════════════════════════════════════════
# PayAgent Environment Configuration
# Copy this to .env and fill in your actual values
# ⚠️  NEVER commit .env to git — it contains secrets
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Cleanverse API (https://cleanverse.com) ────────────────────────────────────
# Register for sandbox: https://api.cleanverse.com/register
CLEANVERSE_API_KEY=your_sandbox_api_key_here
# 32-byte hex string (256-bit AES key) — NEVER sent in requests, stays server-side
CLEANVERSE_AES_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ─── Monad Network ──────────────────────────────────────────────────────────────
# Mainnet: https://rpc.monad.xyz
# Testnet: https://testnet-rpc.monad.xyz
MONAD_RPC_URL=https://rpc.monad.xyz

# ─── Smart Contract Deployment ──────────────────────────────────────────────────
# Your deployer wallet private key (for deploy.js)
DEPLOYER_PRIVATE_KEY=0x...
# Cleanverse compliance oracle address on Monad
COMPLIANCE_ORACLE_ADDRESS=0x...
# Monad USDC address (once deployed on Monad)
MONAD_USDC_ADDRESS=0x...

# ─── JWT / Security ─────────────────────────────────────────────────────────────
# 32+ character secret for token signing
JWT_SECRET=your_jwt_secret_min_32_characters_here

# ─── Optional: Nginx / Production ───────────────────────────────────────────────
# Your domain for CORS and SSL
PRODUCTION_DOMAIN=payagent.yourdomain.com
